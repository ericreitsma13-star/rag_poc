# Copy to .env and adjust values as needed.
# All variables have sensible defaults; only override what you need.

# Directory containing your documents (PDF, DOCX, TXT, MD)
RAG_DATA_DIR=~/local-rag/data

# Qdrant vector store endpoint (local Docker)
QDRANT_URL=http://localhost:6333

# Name of the Qdrant collection
QDRANT_COLLECTION=docs

# Local embedding model (downloaded automatically on first run)
RAG_EMBED_MODEL=intfloat/multilingual-e5-base

# Ollama endpoint (local)
OLLAMA_URL=http://localhost:11434

# Mixtral model tag in Ollama
OLLAMA_MODEL=mixtral:8x7b-instruct-v0.1-q4_K_M

# Number of chunks to retrieve per query
RAG_TOP_K=6

# Target chunk size in characters
RAG_CHUNK_CHARS=1800

# Character overlap between consecutive chunks
RAG_CHUNK_OVERLAP=250
